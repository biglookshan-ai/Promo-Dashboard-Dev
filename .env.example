# Copy to .env locally, or set as Railway variables (never commit real values).
# Embedded app — auth via App Bridge session token + OAuth token exchange.

SHOPIFY_API_KEY=            # Partner app Client ID  (Promo Dashboard Dev)
SHOPIFY_API_SECRET=         # Partner app Client secret
SHOPIFY_API_VERSION=2026-04
DATA_DIR=/data              # Railway Volume mount so exchanged tokens survive redeploys
PORT=3000

# --- Optional: skip token exchange with a fixed Admin API token (single store) ---
# Used by the CLI (scripts/inventory.mjs) and lets the server bypass OAuth.
# SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxx
# SHOPIFY_SHOP=cinegearpro.myshopify.com   # CLI only
